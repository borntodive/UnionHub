{
  "name": "UnionHub",
  "description": "Union Management Platform with AI-powered document generation",
  "version": "1.0.0",
  "type": "docker-compose",
  "compose_file": "docker-compose.prod.yml",
  "env_file": ".env",
  "services": {
    "postgres": {
      "name": "PostgreSQL Database",
      "description": "Main database for UnionHub",
      "ports": ["5432"],
      "volumes": ["postgres_data"],
      "healthcheck": true
    },
    "ollama": {
      "name": "Ollama AI",
      "description": "Local LLM for AI document generation",
      "ports": ["11434"],
      "volumes": ["ollama_data"],
      "healthcheck": true,
      "post_install": [
        "docker exec unionhub-ollama ollama pull mistral"
      ]
    },
    "api": {
      "name": "UnionHub API",
      "description": "NestJS Backend API",
      "ports": ["3000"],
      "depends_on": ["postgres", "ollama"],
      "healthcheck": true
    },
    "nginx": {
      "name": "Nginx Reverse Proxy",
      "description": "Web server and reverse proxy",
      "ports": ["80", "443"],
      "depends_on": ["api"]
    }
  },
  "post_deploy": [
    "echo 'UnionHub deployed successfully!'",
    "echo 'API available at: http://your-server-ip/api'",
    "echo 'Ollama available at: http://your-server-ip:11434'"
  ]
}
