# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=unionhub

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d

# Application
PORT=3000
NODE_ENV=development

# Default Admin (SuperAdmin)
DEFAULT_ADMIN_CREWCODE=SUPERADMIN
DEFAULT_ADMIN_PASSWORD=changeme

# CORS (comma-separated list for multiple origins)
# Examples:
# CORS_ORIGIN=*                                    # Allow all (development only)
# CORS_ORIGIN=http://localhost:8081                # Single origin
# CORS_ORIGIN=http://localhost:8081,http://localhost:19006,https://tua-app.com
CORS_ORIGIN=http://localhost:8081,http://localhost:19006

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# File Storage
# Persistent directory for uploaded files (must survive deployments).
# On Cleavr/production: set to an absolute path outside the deploy folder.
# Example: UPLOAD_BASE_DIR=/var/www/unionhub-uploads
# Leave unset for local development (defaults to <cwd>/uploads).
# UPLOAD_BASE_DIR=/var/www/unionhub-uploads

# Ollama Configuration
# Local setup:
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Cloud setup (es: Ollama Cloud, OpenRouter, Together AI):
# OLLAMA_URL=https://api.openrouter.ai/api/v1
# OLLAMA_MODEL=meta-llama/llama-3.2-70b-instruct
# OLLAMA_API_KEY=your_api_key_here
# OLLAMA_CLOUD=true

# RAG System
# Start Redis + Python service: docker compose -f docker-compose.rag.yml up -d
REDIS_URL=redis://localhost:6379
PYTHON_RAG_URL=http://localhost:8001
PYTHON_RAG_TIMEOUT_MS=120000
PYTHON_RAG_EMBED_BATCH_SIZE=32

# RAG Path Mapping (host -> container)
# When Python RAG runs in Docker, it needs container-internal paths.
# The backend auto-detects these in development; set explicitly for production.
# UPLOAD_HOST_PREFIX=/var/www/unionhub-uploads/rag-docs
# UPLOAD_CONTAINER_PREFIX=/data/rag-docs

# Backup — Google Drive
# Uses the same GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET as Gmail.
# Get the Drive refresh token once with: node scripts/backup-oauth-setup.js
# Run backup: bash scripts/backup.sh  (or via cron: 0 23 * * * ...)
# BACKUP_DRIVE_REFRESH_TOKEN=your_drive_refresh_token_here
# BACKUP_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
