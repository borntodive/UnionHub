# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=unionconnect

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d

# Application
PORT=3000
NODE_ENV=development

# Default Admin (SuperAdmin)
DEFAULT_ADMIN_CREWCODE=SUPERADMIN
DEFAULT_ADMIN_PASSWORD=changeme

# CORS
CORS_ORIGIN=http://localhost:8081

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Ollama Configuration
# Local setup:
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Cloud setup (es: Ollama Cloud, OpenRouter, Together AI):
# OLLAMA_URL=https://api.openrouter.ai/api/v1
# OLLAMA_MODEL=meta-llama/llama-3.2-70b-instruct
# OLLAMA_API_KEY=your_api_key_here
# OLLAMA_CLOUD=true
