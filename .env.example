# ============================================
# UnionHub - Environment Configuration
# ============================================

# --------------------------------------------
# Domain Configuration (for SSL)
# --------------------------------------------
DOMAIN=api.unionhub.app
# Example: api.unionhub.app

# --------------------------------------------
# Database Configuration
# --------------------------------------------
DB_USERNAME=unionhub
DB_PASSWORD=your_secure_password_here_min_16_chars
DB_NAME=unionhub

# --------------------------------------------
# JWT Configuration
# --------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-change-this
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d

# --------------------------------------------
# Ollama Configuration
# --------------------------------------------
OLLAMA_MODEL=mistral
# Options: mistral (7B), llama3.2 (3B), mixtral, phi3
# For 16GB RAM: mistral or llama3.2 recommended

# --------------------------------------------
# Server Configuration
# --------------------------------------------
NODE_ENV=production
PORT=3000

# --------------------------------------------
# Optional: Email Configuration (for notifications)
# --------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# --------------------------------------------
# Optional: Push Notifications (Firebase)
# --------------------------------------------
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=your-private-key
# FIREBASE_CLIENT_EMAIL=your-client-email

# --------------------------------------------
# Optional: S3-compatible Storage (for file uploads)
# --------------------------------------------
# S3_ENDPOINT=s3.eu-central-1.amazonaws.com
# S3_BUCKET=unionhub-uploads
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=eu-central-1
