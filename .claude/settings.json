{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",

    "ANTHROPIC_BASE_URL": "http://localhost:11434",
    "ANTHROPIC_AUTH_TOKEN": "your-auth-token",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ANTHROPIC_MODEL": "kimi-k2.5:cloud",
    "ANTHROPIC_SMALL_FAST_MODEL": "kimi-k2.5:cloud",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "kimi-k2.5:cloud",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "kimi-k2.5:cloud",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "kimi-k2.5:cloud"
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(psql *)",
      "Bash(mongosh *)",
      "Read(**/*.{ts,tsx,js,jsx,json,md})",
      "Write(**/*.{ts,tsx,js,jsx,json,md})"
    ],
    "deny": [],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(npm publish *)",
      "Bash(rm -rf *)",
      "Write(.env*)",
      "Write(package.json)",
      "Write(package-lock.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --check \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "npx eslint --fix \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npm run docs:generate 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "autoUpdatesChannel": "stable"
}
